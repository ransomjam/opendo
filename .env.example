# ----------------------------------------------------------------------------
# Opendo environment configuration
# Copy this file to ".env" and fill in the values you need.
# The app runs fine with NONE of these set; AI features simply stay disabled
# and the app shows a clear message instead of crashing.
# ----------------------------------------------------------------------------

# Core server
PORT=5000
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Runtime storage. Leave blank locally and on Render Free to use the app defaults.
# Only set these when your host provides persistent storage.
DATA_DIR=
UPLOADS_DIR=

# ---- AI features -----------------------------------------------------------
# Master switch. Must be exactly "true" to enable any AI feature.
AI_ENABLED=true

# Google Gemini is used for all AI features.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model names can be set here. Example: gemini-2.5-flash
GEMINI_RESEARCH_MODEL=
GEMINI_WRITING_MODEL=

# After research, automatically save and match results for the user.
AUTO_SAVE_RESEARCH_RESULTS=true
AUTO_MATCH_RESEARCH_RESULTS=true

# ---- admin bootstrap -------------------------------------------------------
# On startup, the app creates/promotes this admin when ADMIN_EMAIL and
# ADMIN_PASSWORD are set. Also used by: npm run create-admin
ADMIN_FULL_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
